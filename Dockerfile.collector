# ── build stage ──────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /collector ./cmd/collector

# ── runtime stage ─────────────────────────────────────────────────────────────
FROM alpine:3.19

RUN adduser -D -g '' appuser
USER appuser

WORKDIR /app

COPY --from=builder /collector .

ENTRYPOINT ["./collector"]